{
  "name": "planning-w-llms",
  "version": "0.1.0",
  "private": true,
  "description": "Frame-grounded hierarchical planning prototype using TypeScript, Bun, and Fastify.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "db:local:launch": "./scripts/db-local-launch.sh",
    "db:local:stop": "./scripts/db-local-stop.sh",
    "dev": "bun --watch src/server.ts",
    "check": "tsc --noEmit",
    "check:packages": "tsc --noEmit -p tsconfig.packages.json",
    "serve": "http-server -p 8000 .",
    "start": "bun run check && bun src/hello.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@babylonjs/core": "^8.53.0",
    "@babylonjs/havok": "^1.3.11",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "bitecs": "^0.4.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.13.8",
    "http-server": "^14.1.1",
    "typescript": "^5.8.2"
  },
  "module": "index.ts"
}
